PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/docbuddy

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_256bit
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRE=30d

# AI Integration (Google Gemini / OpenAI / Custom LLM)
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
CUSTOM_LLM_URL=http://localhost:8000/v1/chat/completions
CUSTOM_LLM_MODEL=docbuddy-medical-v1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload
FILE_UPLOAD_PATH=./uploads
MAX_FILE_UPLOAD=5000000

# CORS
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug
